{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SSH-Buddy",
  "mainBinaryName": "ssh-buddy",
  "version": "0.4.0",
  "identifier": "io.github.quantumflux21.ssh-buddy",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SSH-Buddy",
        "label": "main",
        "width": 1200,
        "height": 760,
        "minWidth": 900,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "QuantumFlux21",
    "homepage": "https://github.com/QuantumFlux21/SSH-Buddy",
    "copyright": "Copyright (c) 2026 SSH-Buddy contributors",
    "license": "MIT OR Apache-2.0",
    "category": "DeveloperTool",
    "shortDescription": "A fast, modern SSH manager for homelab users.",
    "longDescription": "SSH-Buddy is a Linux-first desktop SSH manager for organizing homelab servers, SSH key references, notes, tags, web admin links, ProxyJump/bastion settings, local tunnel profiles, and safe OpenSSH connection actions.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
